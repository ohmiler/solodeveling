{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Local Solodeveling field scorecard",
  "type": "object",
  "required": ["schema", "study_id", "target_observations", "observations"],
  "properties": {
    "schema": {"const": 1},
    "study_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{2,80}$"},
    "target_observations": {"type": "integer", "minimum": 1, "maximum": 100},
    "observations": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": [
          "id",
          "version",
          "tier",
          "task_class",
          "correctness_passed",
          "verification_passed",
          "agent_questions",
          "workflow_artifacts",
          "rework_count",
          "resume_required"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^task-[0-9]{3}$"},
          "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
          "tier": {"enum": ["quick", "standard", "critical"]},
          "task_class": {
            "enum": [
              "documentation",
              "repair",
              "feature",
              "release",
              "production",
              "maintenance",
              "other"
            ]
          },
          "correctness_passed": {"type": "boolean"},
          "verification_passed": {"type": "boolean"},
          "elapsed_seconds": {"type": "number", "minimum": 0},
          "time_to_first_edit_seconds": {"type": "number", "minimum": 0},
          "input_tokens": {"type": "integer", "minimum": 0},
          "output_tokens": {"type": "integer", "minimum": 0},
          "tool_calls": {"type": "integer", "minimum": 0},
          "agent_questions": {"type": "integer", "minimum": 0},
          "workflow_artifacts": {"type": "integer", "minimum": 0},
          "rework_count": {"type": "integer", "minimum": 0},
          "resume_required": {"type": "boolean"},
          "resume_correct": {"type": "boolean"},
          "user_annoyance": {"type": "integer", "minimum": 1, "maximum": 5},
          "ceremony_fit": {"enum": ["too-light", "right", "too-heavy"]}
        },
        "allOf": [
          {
            "if": {
              "properties": {"resume_required": {"const": true}},
              "required": ["resume_required"]
            },
            "then": {"required": ["resume_correct"]}
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
