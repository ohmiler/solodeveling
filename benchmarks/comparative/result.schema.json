{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sanitized comparative benchmark result",
  "type": "object",
  "required": ["schema", "benchmark_id", "classification", "spec_sha256", "provenance", "runs", "summary"],
  "properties": {
    "schema": {"const": 1},
    "benchmark_id": {"type": "string"},
    "classification": {"const": "pilot-signal-only"},
    "spec_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "provenance": {
      "type": "object",
      "required": ["runtime", "methodology_pins", "expected_runs"],
      "properties": {
        "runtime": {"type": "object"},
        "methodology_pins": {"type": "object"},
        "expected_runs": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["run_id", "task_id", "methodology", "repetition", "state", "correct", "elapsed_seconds", "human_interventions", "failure_code", "process_returncode"],
        "properties": {
          "run_id": {"type": "string"},
          "task_id": {"type": "string"},
          "methodology": {"type": "string", "minLength": 1},
          "repetition": {"type": "integer", "minimum": 1},
          "state": {"type": "string"},
          "correct": {"type": "boolean"},
          "elapsed_seconds": {"type": "number", "minimum": 0},
          "input_tokens": {"type": ["integer", "null"], "minimum": 0},
          "cached_input_tokens": {"type": ["integer", "null"], "minimum": 0},
          "output_tokens": {"type": ["integer", "null"], "minimum": 0},
          "tool_calls": {"type": "integer", "minimum": 0},
          "agent_questions": {"type": "integer", "minimum": 0},
          "changed_files": {"type": "integer", "minimum": 0},
          "workflow_artifacts": {"type": "integer", "minimum": 0},
          "human_interventions": {"type": "integer", "minimum": 0},
          "failure_code": {"type": ["string", "null"]},
          "process_returncode": {"type": ["integer", "null"]}
        },
        "additionalProperties": true
      }
    },
    "summary": {"type": "object"}
  },
  "additionalProperties": false
}
